// NewsListenApp のビルド設定（秘密情報）テンプレート。
// 使い方:
//   cp Secrets.example.xcconfig Secrets.xcconfig
//   Secrets.xcconfig に実値を記入（実ファイルは .gitignore 済み・コミット禁止）。
//
// Xcode 側の配線（初回のみ）:
//   Project → Info → Configurations で App ターゲットの Debug/Release の
//   Base Configuration を Secrets.xcconfig に設定する。
//
// 注意: xcconfig では「//」がコメント開始記号。URL の「://」は $() でエスケープする。
//   例) http://localhost:8080  ->  http:/$()/localhost:8080

API_KEY = your-api-key-here
API_BASE_URL = http:/$()/localhost:8080
# Passkey (WebAuthn) の Relying Party ID。
# Associated Domains の webcredentials エントリと一致させること。
# 通常は API ホスト名（例: api.example.com）。
PASSKEY_RP_ID = localhost
